pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Checkout the repository using the correct credentials ID
                git credentialsId: 'github-credentials', url: 'https://github.com/eyaakhalij/bookstore-app.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                // Build the Docker image using docker-compose
                // Make sure to replace the absolute path with the correct one on your Jenkins server
                sh 'docker-compose -f "/c/Users/Eya/Desktop/Book Store/docker-compose.yml" build'
            }
        }

        stage('Test') {
            steps {
                // Run tests 
                sh './run_tests.sh'
            }
        }

        stage('Deploy') {
            steps {
                // Deploy the application using docker-compose
                // Make sure to replace the absolute path with the correct one on your Jenkins server
                sh 'docker-compose -f "/c/Users/Eya/Desktop/Book Store/docker-compose.yml" up -d'
            }
        }
    }
}
