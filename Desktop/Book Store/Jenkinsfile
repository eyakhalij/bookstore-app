pipeline {
    agent any
    environment {
        DOCKER_REGISTRY = "docker.io"
        DOCKER_IMAGE = "eyakhalij/bookstore"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'docker-compose -f "C:/Users/Eya/Desktop/Book Store/docker-compose.yml" build'
            }
        }

        stage('Scan for Vulnerabilities with Trivy') {
            steps {
                script {
                    // Running Trivy to scan the Docker image for vulnerabilities
                    sh 'trivy --no-progress --exit-code 1 --severity HIGH,CRITICAL $DOCKER_IMAGE'
                }
            }
        }

        stage('Test') {
            when {
                expression { return false }  // This will skip the Test stage
            }
            steps {
                sh './run_tests.sh'
            }
        }

        stage('Deploy') {
            when {
                expression { return false }  // This will skip the Deploy stage
            }
            steps {
                echo 'Deploying application...'
            }
        }
    }
    post {
        always {
            cleanWs()
        }
    }
}
