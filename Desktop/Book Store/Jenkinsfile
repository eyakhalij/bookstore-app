pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Clone the repository
                git credentialsId: 'github-credentials', url: 'https://github.com/eyaakhalij/bookstore-app.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                // Build the Docker image using docker-compose
                sh 'docker-compose -f "C:/Users/Eya/Desktop/Book Store/docker-compose.yml" build'
            }
        }

        stage('Test') {
            steps {
                // List files in the workspace to check if run_tests.sh is present
                sh 'ls -l'
                // Ensure that run_tests.sh is executable
                sh 'chmod +x run_tests.sh'
                // Run the test script
                sh './run_tests.sh'
            }
        }

        stage('Deploy') {
            steps {
                // Deploy the app using docker-compose
                sh 'docker-compose -f "C:/Users/Eya/Desktop/Book Store/docker-compose.yml" up -d'
            }
        }
    }
}
