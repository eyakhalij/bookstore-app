pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Checkout the repository using the correct credentials ID
                git credentialsId: 'github-credentials', url: 'https://github.com/eyaakhalij/bookstore-app.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                // Build the Docker image using docker-compose
                // Using the absolute path to docker-compose.yml
                sh 'docker-compose -f "C:/Users/Eya/Desktop/Book Store/docker-compose.yml" build'
            }
        }

        stage('Test') {
            steps {
                // Run tests using the absolute path to the test script
                // Using absolute path to the run_tests.sh file
                sh 'C:/Users/Eya/.jenkins/workspace/Bookstore_Pipeline/run_tests.sh'
            }
        }

        stage('Deploy') {
            steps {
                // Deploy using docker-compose with absolute path to the yaml file
                sh 'docker-compose -f "C:/Users/Eya/Desktop/Book Store/docker-compose.yml" up -d'
            }
        }
    }
}
