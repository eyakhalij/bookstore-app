pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                sh 'docker-compose -f docker-compose.yml build'
            }
        }
        stage('Test') {
            steps {
                sh 'python -m unittest discover -s tests -p "test_flask_app.py"'
            }
        }
        stage('Deploy') {
            steps {
                // Deploy your app here, adjust this part based on your environment.
            }
        }
    }
    post {
        always {
            cleanWs()
        }
    }
}
