pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Checkout the repository
                git credentialsId: 'your-credentials-id', url: 'https://github.com/eyaakhalij/bookstore-app.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                // Build the Docker image using the correct context and path to Dockerfile
                sh 'docker build -t bookstore-app:latest "Desktop/Book Store/"'
            }
        }

        stage('Test') {
            steps {
                // Run tests (if applicable)
                sh './run_tests.sh'
            }
        }

        stage('Deploy') {
            steps {
                // Deploy the application (this can vary based on your setup)
                sh './deploy.sh'
            }
        }
    }
}
